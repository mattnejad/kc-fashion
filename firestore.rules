rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only Kinsey's verified Google account may read or write anything.
    // This is enforced server-side, so no other Google user can access data
    // even if they manage to sign in.
    function isKinsey() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'kinseycathers@gmail.com';
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isKinsey() && request.auth.uid == userId;
    }
  }
}
